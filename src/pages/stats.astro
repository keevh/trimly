---
const slug = (Astro.url.searchParams.get("id") ?? "demo").trim().toLowerCase();
const target = `/s/${encodeURIComponent(slug)}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trimly Stats</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
  </head>
  <body>
    <p>
      Redirigiendo a <a href={target}>{target}</a>
    </p>
  </body>
</html>

