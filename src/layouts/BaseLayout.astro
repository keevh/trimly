---
import { Menu, Scissors } from "lucide-react";
import "../styles/global.css";

interface Props {
  title: string;
  pathname: string;
}

const { title, pathname } = Astro.props;
const isDemoOrStats = pathname === "/demo" || pathname.startsWith("/stats");
const navLinkClass = "text-on-surface-variant font-medium hover:text-primary transition-all duration-200";
const activeNavLinkClass = "text-primary font-medium hover:text-primary transition-all duration-200";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen flex flex-col selection:bg-primary-container selection:text-white">
      <header class="sticky top-0 z-50 w-full bg-surface-container-lowest/80 backdrop-blur-md border-b border-outline-variant">
        <div class="flex justify-between items-center px-4 md:px-10 py-4 w-full max-w-7xl mx-auto">
          <a href="/" class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary-container rounded-xl flex items-center justify-center shadow-[inset_0_1px_rgba(255,255,255,0.2)]">
              <Scissors className="w-5 h-5 text-on-primary" />
            </div>
            <span class="text-xl font-bold tracking-tight text-on-surface">TRIMLY</span>
          </a>

          <nav class="hidden md:flex items-center gap-8">
            <a href="/demo" class={pathname === "/demo" ? activeNavLinkClass : navLinkClass}>Demo</a>
            <a href="/stats?id=demo" class={pathname.startsWith("/stats") ? activeNavLinkClass : navLinkClass}>Stats</a>
            <a href="https://github.com/keevh/trimly" target="_blank" rel="noreferrer" class={navLinkClass}>GitHub</a>
          </nav>

          <button class="md:hidden text-on-surface p-2" type="button" aria-label="Open navigation">
            <Menu className="w-6 h-6" />
          </button>
        </div>
      </header>

      <main class="flex-grow flex flex-col relative z-10 w-full">
        <slot />
      </main>

      <footer class="bg-surface-container-lowest w-full border-t border-outline-variant mt-auto">
        <div class="max-w-7xl mx-auto px-4 md:px-10 py-8 flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex items-center gap-2 text-primary-container">
            <div class="w-6 h-6 bg-primary-container rounded-lg flex items-center justify-center">
              <Scissors className="w-3 h-3 text-on-primary" />
            </div>
            <span class="text-sm font-bold tracking-tight text-on-surface">TRIMLY</span>
          </div>
          <p class="text-xs font-medium text-on-surface-variant text-center tracking-wide">© 2026 TRIMLY OPEN SOURCE PROJECT</p>
          <div class="flex items-center gap-6 text-xs font-medium tracking-widest text-on-surface-variant">
            <a href="https://github.com/keevh/trimly" class="hover:text-primary transition-colors uppercase">GitHub</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
